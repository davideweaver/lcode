{
  "name": "lcode",
  "version": "0.0.1",
  "private": true,
  "description": "Local Claude Code replica: a Claude-Agent-SDK-shaped harness that runs on llama.cpp.",
  "type": "module",
  "bin": {
    "lc": "./dist/bin/lc.js"
  },
  "scripts": {
    "dev": "tsx --tsconfig tsconfig.json bin/lc.ts",
    "start": "tsx bin/lc.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
