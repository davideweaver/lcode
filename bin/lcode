#!/usr/bin/env node

// CLI entry point - runs the TypeScript CLI directly with tsx in development
// or the compiled JS in production
import path from 'path';
import { fileURLToPath } from 'url';
import { spawn } from 'child_process';
import { parseColorFgBg, parseOsc11Response } from './theme-helpers.mjs';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const isDevelopment = process.env.NODE_ENV !== 'production';
const projectRoot = path.join(__dirname, '..');

// Diagnostic flag: run detection only, print raw bytes + parsed result, exit.
if (process.argv.slice(2).includes('--detect-theme')) {
  process.env.LCODE_THEME_DEBUG = '1';
  const result = await detectTheme();
  console.log('\n→ resolved theme:', result);
  process.exit(0);
}

const theme = await detectTheme();
const childEnv = { ...process.env, LCODE_THEME: theme };

if (isDevelopment) {
  // Development: use tsx to run TypeScript directly. Pass an absolute
  // --tsconfig path so tsx honors the project's JSX runtime setting
  // regardless of the user's invocation directory; do NOT set spawn cwd
  // so the child inherits the user's shell cwd.
  const tsxPath = path.join(projectRoot, 'node_modules', '.bin', 'tsx');
  const cliPath = path.join(projectRoot, 'bin', 'lc.ts');
  const tsconfigPath = path.join(projectRoot, 'tsconfig.json');

  const child = spawn(
    tsxPath,
    ['--tsconfig', tsconfigPath, cliPath, ...process.argv.slice(2)],
    { stdio: 'inherit', env: childEnv },
  );

  child.on('exit', (code) => process.exit(code || 0));
} else {
  // Production: run compiled JavaScript
  // Note: In ESM, we use dynamic import() instead of require()
  process.env.LCODE_THEME = theme;
  import(path.join(projectRoot, 'dist', 'bin', 'lc.js')).catch((err) => {
    console.error(err);
    process.exit(1);
  });
}

// Function declaration so it's hoisted — detectTheme() runs at top level
// before const initializers further down would be reached.
function dlog(...a) {
  if (process.env.LCODE_THEME_DEBUG === '1') console.error('[theme]', ...a);
}

/**
 * Resolve the terminal theme: explicit override → COLORFGBG → OSC 11 →
 * default 'dark'. Done before Ink takes over stdin so OSC 11 has a clean
 * channel. Set LCODE_THEME_DEBUG=1 to log decisions to stderr.
 */
async function detectTheme() {
  const override = (process.env.LCODE_THEME ?? '').toLowerCase();
  if (override === 'dark' || override === 'light') {
    dlog('using LCODE_THEME override:', override);
    return override;
  }

  dlog('TERM_PROGRAM=', process.env.TERM_PROGRAM, 'TERM=', process.env.TERM, 'COLORFGBG=', process.env.COLORFGBG);

  const fromEnv = parseColorFgBg(process.env.COLORFGBG);
  if (fromEnv) {
    dlog('resolved from COLORFGBG:', fromEnv);
    return fromEnv;
  }

  if (process.stdin.isTTY && process.stdout.isTTY) {
    const fromOsc = await queryOsc11(500);
    if (fromOsc) {
      dlog('resolved from OSC 11:', fromOsc);
      return fromOsc;
    }
    dlog('OSC 11 query did not yield a usable answer');
  } else {
    dlog('no TTY on stdin/stdout; skipping OSC 11');
  }

  dlog('falling back to default: dark');
  return 'dark';
}

/**
 * Write OSC 11 to stdout and read the terminal's reply from stdin.
 * Resolves to 'dark' / 'light' / null. Resets stdin's raw mode no matter
 * how it exits, so the user's shell isn't left in a weird state.
 */
function queryOsc11(timeoutMs) {
  return new Promise((resolve) => {
    const stdin = process.stdin;
    const stdout = process.stdout;
    if (!stdin.isTTY || !stdout.isTTY || typeof stdin.setRawMode !== 'function') {
      resolve(null);
      return;
    }

    const wasRaw = stdin.isRaw;
    let buf = '';
    let settled = false;

    const cleanup = (result) => {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      stdin.off('data', onData);
      try {
        stdin.setRawMode(wasRaw);
      } catch {
        /* ignore — stdin may already be closed */
      }
      stdin.pause();
      resolve(result);
    };

    const onData = (chunk) => {
      const incoming = chunk.toString('utf8');
      buf += incoming;
      dlog('OSC 11 chunk:', JSON.stringify(incoming));
      const parsed = parseOsc11Response(buf);
      if (parsed) cleanup(parsed);
    };

    try {
      stdin.setRawMode(true);
    } catch {
      resolve(null);
      return;
    }
    stdin.resume();
    stdin.on('data', onData);
    stdout.write('\x1b]11;?\x07');
    const timer = setTimeout(() => {
      dlog('OSC 11 timed out after', timeoutMs, 'ms; buffer:', JSON.stringify(buf));
      cleanup(null);
    }, timeoutMs);
  });
}
