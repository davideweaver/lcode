# OpenAI-compatible base URL of your llama.cpp / router endpoint.
# Either form works (lcode strips a trailing /v1):
#   http://localhost:9200
#   http://llm.appkit.local:9100/v1
LCODE_LLM_URL=http://llm.appkit.local:9100/v1

# Model id the endpoint accepts. Examples:
#   gemma4                     (alias of whatever your router maps it to)
#   qwen2.5-7b-instruct        (good tool-calling out of the box)
#   qwen2.5-coder-7b-instruct  (better for code edits)
LCODE_MODEL=gemma4

# API key. Local llama.cpp ignores it; routers may require a real one.
LCODE_API_KEY=sk-not-needed

# Context window in tokens. Used to compute the statusline %. Override per-model:
#   gemma4 (26B-A4B):           131072
#   qwen2.5-7b-instruct:         32768
#   qwen2.5-coder-7b-instruct:   32768
LCODE_CONTEXT_WINDOW=32768

# SearXNG base URL used by the WebSearch tool. Defaults to the homelab
# instance; override here if you run SearXNG elsewhere.
LCODE_SEARXNG_URL=http://172.16.0.14:3274
